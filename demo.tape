Output demo.gif
Set Theme "Catppuccin Mocha"
Set FontSize 18
Set Width 1000
Set Height 600
Set Padding 20

# show version
Type "relay version"
Enter
Sleep 1.5s

# show all tools
Type "relay tools"
Enter
Sleep 4s

# show status
Type "relay status"
Enter
Sleep 2s

# start the server
Type "relay start"
Enter
Sleep 2s

# done
Type@0 ""
